<!-- HERO -->
<section id="city-photo">
    <div class="hero-text">
        <h1>Sydney, Australia</h1>
        <p>Welcome to our Vivid City of Celebrations!</p>
    </div>
</section>

<main>

<!-- ABOUT -->
<section id="about-city">
    <h2>About the City</h2>

    <div class="about-full">
        <p>Sydney, capital of New South Wales and one of Australia's largest cities, is best known for its harbourfront Sydney Opera House, with a distinctive sail-like design. Massive Darling Harbour and the smaller Circular Quay port are hubs of waterside life, with the arched Harbour Bridge and esteemed Royal Botanic Garden nearby. Sydney Tower’s outdoor platform, the Skywalk, offers 360-degree views of the city and suburbs. </p>
        <p>The city surrounds Sydney Harbour and stretches from the Pacific Ocean to the Blue Mountains.</p>
        <p>It has a rich cultural history dating back more than 30,000 years. Today, Sydney is a global city known for its multicultural population and economy.</p>
    </div>

    <div class="about-highlights">
        <div class="highlight-card">
            <h4>Population</h4>
            <p>5.5M+</p>
        </div>
        <div class="highlight-card">
            <h4>Founded</h4>
            <p>1788</p>
        </div>
        <div class="highlight-card">
            <h4>Nickname</h4>
            <p>Harbour City</p>
        </div>
    </div>
</section>

<!-- ATTRACTIONS -->
<section id="attractions">
    <h2>Top Attractions</h2>

    <div id="city-pics">
        <div class="pics">
            <img src="https://cdn-imgix-open.headout.com/blog/media/images/new/Sydney+Australia.jpg">
            <div class="overlay">Opera House</div>
        </div>

        <div class="pics">
            <img src="https://www.theultimo.com.au/wp-content/uploads/sites/179/2024/05/australia-day-hero-landscape-darling-harbour.jpg">
            <div class="overlay">Darling Harbour</div>
        </div>

        <div class="pics">
            <img src="https://images.rove.me/w_740,q_85/jenol1p4vbsuv6pkttdk/sydney-royal-botanic-garden.jpg">
            <div class="overlay">Botanical Gardens</div>
        </div>
    </div>
</section>

<!-- FLIGHT SEARCH -->
<section id="book-flight">
    <h2 class="search-heading">Search Flights</h2>

<form action="/search-flight" method="POST" onsubmit="return handleSearchSubmit()">

<div class="search-container">

   <div class="search-tabs">
    <span class="tab active" onclick="selectTrip('return')">Return</span>
    <span class="tab" onclick="selectTrip('oneway')">One-way</span>
</div>

    <div class="search-bar">

        <!-- FROM -->
        <div class="search-field">
            <input id="from" name="from" type="text" placeholder="Leaving from" required>
        </div>

        <!-- SWAP -->
        <div class="swap-icon" onclick="swapLocations()">⇄</div>

        <!-- TO -->
        <div class="search-field">
            <input id="to" name="to" type="text" placeholder="Going to" required>
        </div>

        <!-- DATE -->
        <div class="search-field">
            <input id="date" name="date" type="date" required>
        </div>
        <div class="search-field return-date" id="returnDateField">
    <input id="returnDate" name="returnDate" type="date">
</div>

        <!-- TRAVELLERS -->
        <div class="search-field travellers-field" onclick="toggleTravellers()">
            👤 <span id="travellerDisplay">1</span> Traveller

            <div id="travellerDropdown" class="traveller-dropdown">
                <div class="traveller-row">
                    <span>Travellers</span>
                    <div>
                        <button type="button" onclick="changeTravellers('decrease')">-</button>
                        <span id="travellerCount">1</span>
                        <button type="button" onclick="changeTravellers('increase')">+</button>
                    </div>
                </div>
            </div>
        </div>

        <!-- SEARCH -->
        <button type="submit" class="search-btn">Search</button>

    </div>

</div>

</form>
</section>

<!-- MORE INFO -->
<section id="more-info">
    <h2>More Information</h2>

